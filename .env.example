# コピーして .env を作成（.env はコミットしない）

# PostgreSQL 接続
KEIRIN_DB_HOST=localhost
KEIRIN_DB_PORT=5432
KEIRIN_DB_NAME=girls_keirin
KEIRIN_DB_USER=keirin
KEIRIN_DB_PASSWORD=

# Claude API (Phase6 LLM統合)
ANTHROPIC_API_KEY=

# 通知 (Phase5, 任意)
DISCORD_WEBHOOK_URL=
LINE_NOTIFY_TOKEN=

# PWA Web Push（スマホ発走前通知）。`python scripts/gen_vapid.py` で生成して貼る。
# 秘密鍵は絶対にコミットしない（.env のみ）。公開鍵は dashboard/push_config.json にも書かれる。
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com
NOTIFY_LEAD_MIN=10          # 締切の何分前に通知するか（発走≈締切+2〜3分なので10で≒発走12〜13分前）
NOTIFY_ENABLED=1            # 0で通知停止
